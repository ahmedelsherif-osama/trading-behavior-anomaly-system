    "def explain_row(row):\n",
    "    deviations = {\n",
    "        \"trades_per_day\": abs(row[\"trades_per_day_deviation\"]),\n",
    "        \"volume\": abs(row[\"total_trade_volume_per_day_deviation\"]),\n",
    "        \"avg_size\": abs(row[\"avg_trade_size_deviation\"]),\n",
    "        \"time_gap\": abs(row[\"avg_time_between_trades_deviation\"])\n",
    "    }\n",
    "\n",
    "    return sorted(deviations.items(), key=lambda x: x[1], reverse=True)\n",
