   "source": [
    "import numpy as np\n",
    "\n",
    "feature_cols = [\n",
    "    \"trades_per_day\",\n",
    "    \"total_trade_volume_per_day\",\n",
    "    \"avg_trade_size\",\n",
    "    \"avg_time_between_trades\"\n",
    "]\n",
    "\n",
    "baseline_stats = {}\n",
    "\n",
    "for col in feature_cols:\n",
    "    baseline_stats[col] = {\n",
    "        \"mean\": features_df[col].mean(),\n",
    "        \"std\": features_df[col].std(),\n",
    "        \"median\": features_df[col].median()\n",
    "    }\n",
    "\n",
    "baseline_stats"
