    "# placeholder logic for explainability layer\n",
    "\n",
    "def explain_anomaly(row):\n",
    "    reasons = []\n",
    "\n",
    "    if row[\"trades_per_day\"] > 1000:\n",
    "        reasons.append(\"High trading frequency\")\n",
    "\n",
    "    if row[\"total_trade_volume_per_day\"] > 1e7:\n",
    "        reasons.append(\"High volume activity\")\n",
    "\n",
    "    if row[\"avg_time_between_trades\"] < 60:\n",
    "        reasons.append(\"Burst trading behavior\")\n",
    "\n",
    "    return reasons\n",
    "\n",
    "df_results[\"reasons\"] = df_results.apply(explain_anomaly, axis=1)\n",
    "df_results[[\"Account\", \"date\", \"reasons\"]].head()"
