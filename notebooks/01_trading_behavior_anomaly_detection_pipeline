    "    .groupby(\"Account\")[\"Timestamp\"]\n",
    "    .diff()\n",
    "    .dt.total_seconds()\n",
    ")\n",
    "\n",
    "# average time gap per account/day\n",
    "avg_time_between = (\n",
    "    df_sorted\n",
    "    .groupby([\"Account\", \"date\"])[\"time_diff\"]\n",
    "    .mean()\n",
    "    .reset_index(name=\"avg_time_between_trades\")\n",
