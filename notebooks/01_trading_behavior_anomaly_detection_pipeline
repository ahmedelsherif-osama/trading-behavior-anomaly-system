    "# sort trades chronologically per account\n",
    "df_sorted = historical_df.sort_values([\"Account\", \"Timestamp\"])\n",
    "\n",
    "# time difference between consecutive trades for same account\n",
    "df_sorted[\"time_diff\"] = (\n",
